fn register_plural_translations(translations: &mut HashMap<String, String>) {
    // Para las formas plurales, usamos una estructura de map anidada
    let mut plurals = HashMap::new();
    
    // Plurals for minutes
    let mut minutes_ago = HashMap::new();
    minutes_ago.insert(0, "%n minute temu".to_string());
    minutes_ago.insert(1, "%n minut temu".to_string());
    minutes_ago.insert(2, "%n minut temu".to_string());
    
    // Plurals for hours
    let mut hours_ago = HashMap::new();
    hours_ago.insert(0, "%n godzine temu".to_string());
    hours_ago.insert(1, "%n godzin temu".to_string());
    hours_ago.insert(2, "%n godzin temu".to_string());
    
    // Plurals for days
    let mut days_ago = HashMap::new();
    days_ago.insert(0, "%n dzień temu".to_string());
    days_ago.insert(1, "%n dni temu".to_string());
    days_ago.insert(2, "%n dni temu".to_string());
    
    // Plurals for months
    let mut months_ago = HashMap::new();
    months_ago.insert(0, "%n miesiąc temu".to_string());
    months_ago.insert(1, "%n miesięcy temu".to_string());
    months_ago.insert(2, "%n miesięcy temu".to_string());
    
    // Plurals for file conflicts
    let mut file_conflicts = HashMap::new();
    file_conflicts.insert(0, "{count} konfliktów plików".to_string());
    file_conflicts.insert(1, "{count} konfliktów plików".to_string());
    file_conflicts.insert(2, "{count} konfliktów plików".to_string());
    
    // Add plurals to the main plural map
    plurals.insert("_%n minute ago_::_%n minutes ago_".to_string(), minutes_ago);
    plurals.insert("_%n hour ago_::_%n hours ago_".to_string(), hours_ago);
    plurals.insert("_%n day ago_::_%n days ago_".to_string(), days_ago);
    plurals.insert("_%n month ago_::_%n months ago_".to_string(), months_ago);
    plurals.insert("_{count} file conflict_::_{count} file conflicts_".to_string(), file_conflicts);
    
    // Polish has 3 plural forms
    // Define the plural forms rule function for Polish language
    pub fn get_plural_form(n: i64) -> usize {
        if n == 1 {
            return 0;
        } else if n % 10 >= 2 && n % 10 <= 4 && (n % 100 < 10 || n % 100 >= 20) {
            return 1;
        } else {
            return 2;
        }
    }
}

// Implementación de la información de la localización
pub fn get_locale_info() -> LocaleInfo {
    LocaleInfo {
        code: "pl".to_string(),
        plural_forms: "nplurals=3; plural=(n==1 ? 0 : n%10>=2 && n%10<=4 && (n%100<10 || n%100>=20) ? 1 : 2);".to_string(),
    }
}

// Definimos una estructura para la información de la localización
pub struct LocaleInfo {
    pub code: String,
    pub plural_forms: String,
}