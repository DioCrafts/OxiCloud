use lazy_static::lazy_static;
use std::collections::HashMap;

lazy_static! {
    pub static ref TRANSLATIONS: HashMap<&'static str, &'static str> = {
        let mut m = HashMap::new();
        m.insert("Error", "خاتالىق");
        m.insert("Nothing in here. Your trash bin is empty!", "بۇ جايدا ھېچنېمە يوق. Your trash bin is empty!");
        m.insert("Name", "ئاتى");
        m.insert("Deleted", "ئۆچۈرۈلدى");
        m.insert("Delete", "ئۆچۈر");
        m
    };

    pub static ref PLURAL_FORMS: &'static str = "nplurals=1; plural=0;";
}